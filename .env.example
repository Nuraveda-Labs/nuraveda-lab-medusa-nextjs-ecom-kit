# ─── Storefront (Next.js) ────────────────────────────────────────────────
# Public brand identity — safe to expose to the browser.
NEXT_PUBLIC_BRAND_NAME=Storefront
NEXT_PUBLIC_BRAND_TAGLINE=A modern e-commerce starter built with Next.js and Medusa.
NEXT_PUBLIC_BRAND_CURRENCY=USD
NEXT_PUBLIC_BRAND_LOCALE=en-US
NEXT_PUBLIC_BRAND_INSTAGRAM=
NEXT_PUBLIC_BRAND_TWITTER=
NEXT_PUBLIC_BRAND_FACEBOOK=

# ─── Medusa backend connection ───────────────────────────────────────────
MEDUSA_BACKEND_URL=http://127.0.0.1:9000
MEDUSA_PUBLISHABLE_KEY=pk_your_publishable_key_here
MEDUSA_REGION_ID=reg_your_region_id_here
NEXT_PUBLIC_MEDUSA_REGION_ID=reg_your_region_id_here

# Admin API (server-side only — used by scripts/order automation).
MEDUSA_ADMIN_EMAIL=admin@example.com
MEDUSA_ADMIN_PASSWORD=change_me

# ─── Analytics (optional — leave blank to disable) ───────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
META_CONVERSIONS_ACCESS_TOKEN=

# ─── Payments (placeholder) ──────────────────────────────────────────────
# This starter ships with a PLACEHOLDER payment step so it runs out of the box.
# Wire your own provider (Stripe, PayPal, etc.) — see
# src/app/api/payments/ and the README "Payments" section.
PAYMENT_PROVIDER=placeholder

# ─── Email (optional) ────────────────────────────────────────────────────
# SMTP or transactional provider for order confirmations. Leave blank to skip.
SMTP_URL=
ORDER_FROM_EMAIL=orders@example.com
